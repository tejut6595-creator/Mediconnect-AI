{
  "version": 2,
  "name": "mediconnect-ai",
  "buildCommand": "cd mediconnect-frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "mediconnect-frontend/build",
  "installCommand": "echo 'skip root install'",
  "framework": null,
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
